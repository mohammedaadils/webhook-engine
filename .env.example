# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Commit this file to Git.
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in real values in .env
#   3. .env is in .gitignore — it NEVER gets committed
# ─────────────────────────────────────────────────────────────────────────────

# MySQL database name (created automatically on first docker-compose up)
DB_NAME=webhookdb

# MySQL username (not root — least-privilege principle)
DB_USER=webhookuser

# MySQL password — change this to something strong on EC2
DB_PASSWORD=changeme
